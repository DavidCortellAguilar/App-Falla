# =====================================================================
# .htaccess – app.fssaf.es (Hostinger + Cloudflare)
# =====================================================================

Options -Indexes
ServerSignature Off

# ─── Bloquear acceso directo a archivos sensibles ────────────────────
<FilesMatch "\.(sql|lock|log|env)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(config\.php|composer\.json|composer\.lock|generar-vapid\.php)$">
    Require all denied
</FilesMatch>

# ─── Rewrite: HTTPS y bloqueo de directorios ─────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forzar HTTPS respetando el proxy de Cloudflare
    # (Cloudflare envía X-Forwarded-Proto: https al origen)
    RewriteCond %{HTTP:X-Forwarded-Proto} =http [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Bloquear acceso directo a vendor/
    RewriteRule ^vendor(/|$) - [F,L]

    # Solo permitir imágenes en uploads/
    RewriteCond %{REQUEST_URI} ^/uploads/
    RewriteCond %{REQUEST_URI} !\.(jpg|jpeg|png|gif|webp)$ [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ─── No cachear respuestas PHP ────────────────────────────────────────
# Evita que Cloudflare sirva páginas PHP cacheadas con sesiones antiguas
<IfModule mod_headers.c>
    <FilesMatch "\.php$">
        Header always set Cache-Control "no-store, private, max-age=0"
        Header always set Pragma "no-cache"
        Header always unset ETag
    </FilesMatch>
</IfModule>

# ─── Cachear assets estáticos ─────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/jpg              "access plus 1 year"
    ExpiresByType image/gif              "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType image/x-icon           "access plus 1 year"
    ExpiresByType text/css               "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType application/json       "access plus 0 seconds"
</IfModule>

# ─── Compresión gzip ─────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
